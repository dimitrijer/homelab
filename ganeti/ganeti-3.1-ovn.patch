+"""OVN integration helper functions for Ganeti.
+
+This module provides functions for managing OVN logical switch ports
+during instance lifecycle and live migration.
+
+"""
+
+import logging
+
+from ganeti import utils
+from ganeti import errors
+from ganeti import constants
+
+
+def _RunOVNCommand(args, nb_connection=None, error_msg="OVN command failed"):
+  """Run an ovn-nbctl command.
+
+  @type args: list of strings
+  @param args: Command arguments for ovn-nbctl
+  @type nb_connection: string or None
+  @param nb_connection: OVN NB database connection string (optional)
+  @type error_msg: string
+  @param error_msg: Error message prefix
+  @rtype: string
+  @return: Command output
+  @raises HypervisorError: On command failure
+
+  """
+  cmd = ["ovn-nbctl"]
+
+  # Add database connection if specified
+  if nb_connection:
+    cmd.extend(["--db", nb_connection])
+
+  cmd.extend(args)
+
+  result = utils.RunCmd(cmd)
+
+  # WORKAROUND: Cannot rely on exit codes when running in job context
+  #
+  # Root cause: The luxid daemon sets SIGCHLD=SIG_IGN for automatic zombie
+  # process reaping. When SIGCHLD is explicitly ignored (not just default
+  # ignored), POSIX.1-2001 specifies that child processes are automatically
+  # reaped by the kernel, but the parent loses access to child exit status
+  # information. As a result, subprocess.wait() may return exit code 0
+  # even when the child process actually exited with a non-zero code.
+  #
+  # This affects ovn-nbctl when run from luxid job context:
+  # - In luxid jobs: SIGCHLD ignored → ovn-nbctl returns exit code 0 on error
+  # - In gnt-debug: SIGCHLD not ignored → ovn-nbctl returns correct exit code 1
+  #
+  # Solution: Check command output for error indicators like "no row" instead
+  # of relying solely on exit codes. This is the correct and necessary approach
+  # given POSIX signal handling semantics.
+  #
+  # See test_sigchld_exit_code.py for verification of this behavior.
+  if result.failed or "no row" in result.output:
+    raise errors.HypervisorError(
+        "%s: %s; output: %s" % (error_msg, result.fail_reason or "command output indicates error", result.output))
+
+  return result.output.strip()
+
+
+def GetOVNPortId(nic):
+  """Generate OVN logical switch port ID for instance NIC.
+
+  @type nic: L{objects.NIC}
+  @param nic: NIC object
+  @rtype: string
+  @return: Port ID string (NIC UUID)
+
+  """
+  return nic.uuid
+
+
+def CreateOVNPort(instance, nic_idx, nic, nb_connection=None):
+  """Create OVN logical switch port for instance NIC.
+
+  @type instance: L{objects.Instance}
+  @param instance: Instance object
+  @type nic_idx: int
+  @param nic_idx: NIC index (0-based)
+  @type nic: L{objects.NIC}
+  @param nic: NIC object
+  @type nb_connection: string or None
+  @param nb_connection: OVN NB database connection string (optional)
+
+  """
+  port_id = GetOVNPortId(nic)
+
+  lswitch = nic.nicparams.get(constants.NIC_OVN_LOGICAL_SWITCH)
+  if not lswitch:
+    raise errors.HypervisorError(
+        "NIC has no ovn_logical_switch parameter set (nicparams: %s)" % nic.nicparams)
+
+  # Check if port already exists
+  try:
+    _RunOVNCommand(["list", "logical_switch_port", port_id],
+                   nb_connection, "Check port existence")
+    # Port exists, reuse it
+    logging.info("OVN port %s already exists, reusing", port_id)
+    return
+  except errors.HypervisorError:
+    # Port doesn't exist (command failed), create it
+    pass
+
+  # Create logical switch port
+  _RunOVNCommand(
+      ["lsp-add", lswitch, port_id],
+      nb_connection,
+      "Failed to create OVN port %s" % port_id)
+
+  # Set addresses (MAC and optionally IP)
+  addresses = nic.mac
+  if nic.ip:
+    addresses = "%s %s" % (nic.mac, nic.ip)
+
+  _RunOVNCommand(
+      ["lsp-set-addresses", port_id, addresses],
+      nb_connection,
+      "Failed to set addresses for port %s" % port_id)
+
+  # Set port security (prevent MAC/IP spoofing)
+  _RunOVNCommand(
+      ["lsp-set-port-security", port_id, addresses],
+      nb_connection,
+      "Failed to set port security for port %s" % port_id)
+
+  # Set neutron:port_name external ID for compatibility
+  port_name = "%s_nic%d" % (instance.name, nic_idx)
+  _RunOVNCommand(
+      ["set", "logical_switch_port", port_id,
+       "external_ids:\"neutron:port_name\"=\"%s\"" % port_name],
+      nb_connection,
+      "Failed to set external ID for port %s" % port_id)
+
+  # Set neutron:network_name external ID to the logical switch name
+  _RunOVNCommand(
+      ["set", "logical_switch_port", port_id,
+       "external_ids:\"neutron:network_name\"=\"%s\"" % lswitch],
+      nb_connection,
+      "Failed to set neutron:network_name external ID for port %s" % port_id)
+
+  # Set DHCP options if ovn_dhcpv4_options is specified
+  dhcp_options = nic.nicparams.get(constants.NIC_OVN_DHCPV4_OPTIONS)
+  if dhcp_options:
+    _RunOVNCommand(
+        ["lsp-set-dhcpv4-options", port_id, dhcp_options],
+        nb_connection,
+        "Failed to set DHCPv4 options for port %s" % port_id)
+    logging.info("Set DHCPv4 options %s for port %s", dhcp_options, port_id)
+
+  logging.info("Created OVN port %s on logical switch %s", port_id, lswitch)
+
+
+def SetMultiChassisBinding(nic, source_chassis, dest_chassis,
+                           nb_connection=None):
+  """Enable multi-chassis port binding for migration.
+
+  This sets the OVN port's requested-chassis option to a comma-separated
+  list of source and destination chassis. OVN will then clone traffic
+  to both locations, enabling near-zero-downtime migration.
+
+  @type nic: L{objects.NIC}
+  @param nic: NIC object
+  @type source_chassis: string
+  @param source_chassis: Source chassis name
+  @type dest_chassis: string
+  @param dest_chassis: Destination chassis name
+  @type nb_connection: string or None
+  @param nb_connection: OVN NB database connection string (optional)
+
+  """
+  port_id = GetOVNPortId(nic)
+
+  # Set requested-chassis to "source,destination"
+  # The first chassis is primary, additional chassis also receive traffic
+  chassis_list = "%s,%s" % (source_chassis, dest_chassis)
+
+  _RunOVNCommand(
+      ["lsp-set-options", port_id, "activation-strategy=rarp", "requested-chassis=%s" % chassis_list],
+      nb_connection,
+      "Failed to set multi-chassis binding for port %s" % port_id)
+
+  logging.info("OVN: Set multi-chassis binding for %s: %s",
+               port_id, chassis_list)
+
+
+def ClearMultiChassisBinding(nic, final_chassis, nb_connection=None):
+  """Clear multi-chassis binding, keep only final chassis.
+
+  This should be called after migration completes to remove the
+  multi-chassis binding and bind the port to only the destination chassis.
+
+  @type nic: L{objects.NIC}
+  @param nic: NIC object
+  @type final_chassis: string
+  @param final_chassis: Final chassis name
+  @type nb_connection: string or None
+  @param nb_connection: OVN NB database connection string (optional)
+
+  """
+  port_id = GetOVNPortId(nic)
+
+  # Set requested-chassis to single chassis
+  _RunOVNCommand(
+      ["lsp-set-options", port_id, "requested-chassis=%s" % final_chassis],
+      nb_connection,
+      "Failed to clear multi-chassis binding for port %s" % port_id)
+
+  logging.info("OVN: Cleared multi-chassis binding for %s, now on %s",
+               port_id, final_chassis)
+
+
+def SetRequestedChassis(nic, chassis, nb_connection=None):
+  """Set requested-chassis option for OVN logical switch port.
+
+  This binds the port to a specific chassis, typically used when starting
+  an instance to ensure the port is bound to the node where the instance runs.
+
+  @type nic: L{objects.NIC}
+  @param nic: NIC object
+  @type chassis: string
+  @param chassis: Chassis name
+  @type nb_connection: string or None
+  @param nb_connection: OVN NB database connection string (optional)
+
+  """
+  port_id = GetOVNPortId(nic)
+
+  _RunOVNCommand(
+      ["lsp-set-options", port_id, "requested-chassis=%s" % chassis],
+      nb_connection,
+      "Failed to set requested-chassis for port %s" % port_id)
+
+  logging.info("OVN: Set requested-chassis=%s for port %s", chassis, port_id)
+
+
+def DeleteOVNPort(nic, nb_connection=None):
+  """Delete OVN logical switch port.
+
+  @type nic: L{objects.NIC}
+  @param nic: NIC object
+  @type nb_connection: string or None
+  @param nb_connection: OVN NB database connection string (optional)
+
+  """
+  port_id = GetOVNPortId(nic)
+
+  try:
+    _RunOVNCommand(
+        ["lsp-del", port_id],
+        nb_connection,
+        "Failed to delete OVN port %s" % port_id)
+    logging.info("Deleted OVN port %s", port_id)
+  except errors.HypervisorError as err:
+    # Port might not exist, log but don't fail
+    logging.warning("Could not delete OVN port %s: %s", port_id, err)
+
+
+def VerifyOVNConnectivity(nb_connection=None):
+  """Verify OVN northbound database is accessible.
+
+  @type nb_connection: string or None
+  @param nb_connection: OVN NB database connection string (optional)
+  @raises HypervisorError: If OVN NB is not accessible
+
+  """
+  try:
+    _RunOVNCommand(["show"], nb_connection, "OVN connectivity check failed")
+  except errors.HypervisorError as err:
+    raise errors.HypervisorError(
+        "Cannot connect to OVN northbound database: %s" % err)
+
+
+def HasOVNNics(instance):
+  """Check if instance has any OVN-mode NICs.
+
+  @type instance: L{objects.Instance}
+  @param instance: Instance object
+  @rtype: bool
+  @return: True if instance has at least one OVN NIC
+
+  """
+  return any(nic.nicparams.get(constants.NIC_MODE) == constants.NIC_MODE_OVN
+             for nic in instance.nics)
+
+
+def GetChassisName(node_name):
+  """Get OVN chassis name for a Ganeti node.
+
+  By convention, OVN chassis name typically matches the node hostname.
+  This function can be enhanced to query OVN SB for the actual mapping
+  if needed.
+
+  @type node_name: string
+  @param node_name: Ganeti node name
+  @rtype: string
+  @return: Chassis name
+
+  """
+  # In most setups, chassis name == hostname
+  # If your setup uses different naming, modify this function
+  return node_name.split('.')[0]

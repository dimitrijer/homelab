+class TestDRBD84CmdGenerator(testutils.GanetiTestCase):
+  """Tests 8.4 command generation that the DRBD 9 support relies on"""
+
+  def setUp(self):
+    testutils.GanetiTestCase.setUp(self)
+    version = {
+      "k_major": 8,
+      "k_minor": 4,
+      "k_point": 11,
+      "api": 1,
+      "proto": 86,
+      "proto2": "101",
+    }
+    self.cmd_gen = drbd_cmdgen.DRBD84CmdGenerator(version)
+    self.params = {
+      constants.LDP_BARRIERS: "n",
+      constants.LDP_NO_META_FLUSH: False,
+      constants.LDP_DISK_CUSTOM: "",
+      constants.LDP_NET_CUSTOM: "",
+      constants.LDP_DYNAMIC_RESYNC: False,
+      constants.LDP_RESYNC_RATE: 1024,
+      constants.LDP_PROTOCOL: "C",
+    }
+
+  def testInitCmdsCreateResource(self):
+    """8.4 local/net init commands must create the resource inline"""
+    local_cmds = self.cmd_gen.GenLocalInitCmds(0, "/dev/xenvg/test.data",
+                                               "/dev/xenvg/test.meta",
+                                               1024, self.params)
+    net_cmds = self.cmd_gen.GenNetInitCmds(0, "ipv4", "192.0.2.1", 11000,
+                                           "192.0.2.2", 11000, "C", False,
+                                           "md5", "secret", self.params)
+    for cmds in [local_cmds, net_cmds]:
+      self.assertEqual([cmd[1] for cmd in cmds[:2]],
+                       ["new-resource", "new-minor"])
+
+  def testSyncParamsCmd(self):
+    self.assertEqual(self.cmd_gen.GenSyncParamsCmd(0, self.params),
+                     ["drbdsetup", "disk-options", 0,
+                      "--resync-rate", "1024"])
+
+  def testSyncParamsInvalid(self):
+    """dynamic-resync with c-plan-ahead=0 must raise, not return a command"""
+    self.params[constants.LDP_DYNAMIC_RESYNC] = True
+    self.params[constants.LDP_PLAN_AHEAD] = 0
+    self.assertRaises(errors.BlockDeviceError,
+                      self.cmd_gen.GenSyncParamsCmd, 0, self.params)
+
+
+class TestDRBD9CmdGenerator(testutils.GanetiTestCase):
+  """Tests the drbdsetup commands generated for DRBD 9.x kernels"""
+
+  def setUp(self):
+    testutils.GanetiTestCase.setUp(self)
+    version = {
+      "k_major": 9,
+      "k_minor": 3,
+      "k_point": 3,
+      "api": 2,
+      "proto": 118,
+      "proto2": "124",
+    }
+    self.cmd_gen = drbd_cmdgen.DRBD9CmdGenerator(version)
+    self.params = {
+      constants.LDP_BARRIERS: "n",
+      constants.LDP_NO_META_FLUSH: False,
+      constants.LDP_DISK_CUSTOM: "",
+      constants.LDP_NET_CUSTOM: "",
+      constants.LDP_DYNAMIC_RESYNC: False,
+      constants.LDP_RESYNC_RATE: 1024,
+      constants.LDP_PROTOCOL: "C",
+    }
+
+  def testResourceInitCmds(self):
+    self.assertEqual(self.cmd_gen.GenResourceInitCmds(0),
+                     [["drbdsetup", "new-resource", "resource0"],
+                      ["drbdsetup", "new-minor", "resource0", "0", "0"]])
+
+  def testShowCmd(self):
+    self.assertEqual(self.cmd_gen.GenShowCmd(0),
+                     ["drbdsetup", "show", "resource0", "--json"])
+
+  def testLocalInitCmds(self):
+    """Resource creation commands must not be part of the local init"""
+    cmds = self.cmd_gen.GenLocalInitCmds(0, "/dev/xenvg/test.data",
+                                         "/dev/xenvg/test.meta",
+                                         1024, self.params)
+    self.assertEqual([cmd[:2] for cmd in cmds],
+                     [["drbdmeta", "/dev/drbd0"],
+                      ["drbdsetup", "attach"]])
+
+  def testNetInitCmds(self):
+    """Resource creation commands must not be part of the net init"""
+    cmds = self.cmd_gen.GenNetInitCmds(0, "ipv4", "192.0.2.1", 11000,
+                                       "192.0.2.2", 11000, "C", False,
+                                       "md5", "secret", self.params)
+    self.assertEqual(len(cmds), 1)
+    self.assertEqual(cmds[0][:5],
+                     ["drbdsetup", "connect", "resource0",
+                      "ipv4:192.0.2.1:11000", "ipv4:192.0.2.2:11000"])
+
+  def testSyncParamsCmd(self):
+    self.assertEqual(self.cmd_gen.GenSyncParamsCmd(0, self.params, 1),
+                     ["drbdsetup", "peer-device-options", "resource0",
+                      "1", "0", "--resync-rate", "1024"])
+
+  def testSyncParamsInvalid(self):
+    """dynamic-resync with c-plan-ahead=0 must raise, not return a command"""
+    self.params[constants.LDP_DYNAMIC_RESYNC] = True
+    self.params[constants.LDP_PLAN_AHEAD] = 0
+    self.assertRaises(errors.BlockDeviceError,
+                      self.cmd_gen.GenSyncParamsCmd, 0, self.params, 1)
+
+  def testPauseResumeSyncCmds(self):
+    self.assertEqual(self.cmd_gen.GenPauseSyncCmd(0, 1),
+                     ["drbdsetup", "pause-sync", "resource0", "1", "0"])
+    self.assertEqual(self.cmd_gen.GenResumeSyncCmd(0, 1),
+                     ["drbdsetup", "resume-sync", "resource0", "1", "0"])
+
+  def testPrimarySecondaryCmds(self):
+    self.assertEqual(self.cmd_gen.GenPrimaryCmd(0, False),
+                     ["drbdsetup", "primary", "resource0"])
+    self.assertEqual(self.cmd_gen.GenPrimaryCmd(0, True),
+                     ["drbdsetup", "primary", "resource0", "--force"])
+    self.assertEqual(self.cmd_gen.GenSecondaryCmd(0),
+                     ["drbdsetup", "secondary", "resource0"])
+
+  def testDisconnectCmd(self):
+    self.assertEqual(self.cmd_gen.GenDisconnectCmd(0, 1),
+                     ["drbdsetup", "del-peer", "resource0", "1"])
+
+  def testInheritedCmds(self):
+    """Commands inherited from the 8.4 generator that work as-is on 9.x"""

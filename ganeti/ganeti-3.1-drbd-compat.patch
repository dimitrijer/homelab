+class DRBD9CmdGenerator(DRBD84CmdGenerator):
+  """Generates drbdsetup commands for DRBD 9.x kernels (drbd8 compat mode).
+
+  DRBD 9 nodes are driven through the same drbd8-style command sequence as
+  DRBD 8.4 nodes: drbd-utils translates most of it, and creating the
+  resource without a node id puts it into the kernel's drbd8 compat mode
+  (single peer, v08 metadata, 8.4-style /proc/drbd output). Only the
+  commands drbd-utils does not translate are overridden here:
+
+    - resources/minors must be created exactly once (DRBD 9 rejects a
+      repeated new-minor), hence RESOURCE_INIT_INLINE is False and the
+      caller runs GenResourceInitCmds separately
+    - primary/secondary take a resource name instead of a minor
+    - the resync options moved from disk-options to peer-device-options,
+      which also require the peer (node id) to be configured first
+    - show only supports the DRBD 9 output formats; we use --json
+
+  """
+  NEEDS_PEER_NODE_ID = True
+
+  RESOURCE_INIT_INLINE = False
+
+  # The resync options are peer-device options and can only be applied
+  # once the peer is configured, i.e. after connecting.
+  SYNC_PARAMS_PHASE = SYNC_PARAMS_POST_CONN
+
+  def GenShowCmd(self, minor):
+    return ["drbdsetup", "show", self._GetResource(minor), "--json"]
+
+  # pylint: disable=W0221
+  def GenSyncParamsCmd(self, minor, params, peer_node_id):
+    return ["drbdsetup", "peer-device-options", self._GetResource(minor),
+            str(peer_node_id), "0"] + self._GenResyncOpts(params)
+
+  # pylint: disable=W0221
+  def GenDisconnectCmd(self, minor, peer_node_id):
+    # del-peer both disconnects and removes the connection object, so
+    # that a subsequent (drbd8-style) connect can recreate the peer and
+    # path from scratch. The peer addresses of the 8.4 signature are not
+    # needed: the peer node id fully identifies the connection.
+    return ["drbdsetup", "del-peer", self._GetResource(minor),
+            str(peer_node_id)]
+
+  def GenPauseSyncCmd(self, minor, peer_node_id):
+    return ["drbdsetup", "pause-sync", self._GetResource(minor),
+            str(peer_node_id), "0"]
+
+  def GenResumeSyncCmd(self, minor, peer_node_id):
+    return ["drbdsetup", "resume-sync", self._GetResource(minor),
+            str(peer_node_id), "0"]
+
+  def GenPrimaryCmd(self, minor, force):
+    cmd = ["drbdsetup", "primary", self._GetResource(minor)]
+
+    if force:
+      cmd.append("--force")
+
+    return cmd
+
+  def GenSecondaryCmd(self, minor):
+    return ["drbdsetup", "secondary", self._GetResource(minor)]

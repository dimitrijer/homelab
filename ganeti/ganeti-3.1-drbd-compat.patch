+class DRBD9ShowInfo(object):
+  """Parses the JSON output of `drbdsetup show <resource> --json`.
+
+  Used for DRBD 9.x resources running in drbd8 compat mode. Unlike the
+  8.x classes this does not use pyparsing: the --json output is parsed
+  directly. Only the single-volume, single-peer layout created by Ganeti
+  (via the drbd8-style command sequence) is supported.
+
+  """
+  @classmethod
+  def _ParseAddress(cls, address):
+    return (address["address"], int(address["port"]))
+
+  @classmethod
+  def GetDevInfo(cls, show_data):
+    """Parse details about a given DRBD resource.
+
+    Returns a dict with the same keys as L{BaseShowInfo.GetDevInfo}
+    (except C{meta_index}, which flex-external metadata does not have),
+    plus C{peer_node_id} once a peer connection is configured.
+
+    """
+    retval = {}
+
+    if not show_data:
+      return retval
+
+    try:
+      resources = serializer.LoadJson(show_data)
+    except ValueError as err:
+      base.ThrowError("Can't parse drbdsetup show output: %s", str(err))
+
+    if not isinstance(resources, list) or not resources:
+      return retval
+
+    resource = resources[0]
+
+    volumes = resource.get("_this_host", {}).get("volumes", [])
+    if len(volumes) == 1:
+      volume = volumes[0]
+      if isinstance(volume.get("backing-disk"), str):
+        retval["local_dev"] = volume["backing-disk"]
+      if isinstance(volume.get("meta-disk"), str):
+        retval["meta_dev"] = volume["meta-disk"]
+
+    connections = resource.get("connections", [])
+    if len(connections) == 1:
+      connection = connections[0]
+      if "_peer_node_id" in connection:
+        retval["peer_node_id"] = connection["_peer_node_id"]
+      paths = connection.get("paths", [])
+      if len(paths) == 1:
+        path = paths[0]
+        if "this_host" in path:
+          retval["local_addr"] = cls._ParseAddress(path["this_host"])
+        if "remote_host" in path:
+          retval["remote_addr"] = cls._ParseAddress(path["remote_host"])
+
+    return retval
